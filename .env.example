# ============================================================
# Beancount-Trans 自托管环境变量配置
# 使用方法: cp .env.example .env  然后按需修改
# ============================================================

# ==================== Django 核心 ====================
DJANGO_SETTINGS_MODULE=project.settings.settings

# 安全密钥（生产环境务必替换为随机字符串）
# 生成命令: python3 -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=please-change-me-to-a-random-string

# 调试模式：True 时自动放行所有域名和跨域请求，适合本地使用
# 如果需要从其他设备访问，设为 False 并配置下方 ALLOWED_HOSTS 和 CORS
DJANGO_DEBUG=True

# 以下两项仅在 DJANGO_DEBUG=False 时生效
# DJANGO_ALLOWED_HOSTS=your-domain.com,192.168.1.100
# CSRF_TRUSTED_ORIGINS=http://your-domain.com,http://192.168.1.100:38001
# CORS_ALLOWED_ORIGINS=http://your-domain.com:38001

# ==================== PostgreSQL ====================
TRANS_POSTGRESQL_DATABASE=beancount-trans
TRANS_POSTGRESQL_USER=root
TRANS_POSTGRESQL_PASSWORD=root
TRANS_POSTGRESQL_HOST=beancount-trans-postgres
TRANS_POSTGRESQL_PORT=5432

# ==================== Redis ====================
TRANS_REDIS_HOST=beancount-trans-redis
TRANS_REDIS_PORT=6379
TRANS_REDIS_PASSWORD=root

# ==================== 对象存储 (MinIO) ====================
STORAGE_TYPE=minio
MINIO_ENDPOINT=beancount-trans-minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=beancount-trans
MINIO_USE_HTTPS=False

# ==================== 认证策略（自托管）====================
# 生产环境可不设置：默认 PHONE_BINDING_REQUIRED=True、SMS_ENABLED=True（与线上一致）
# 自托管无短信时建议关闭短信并放宽手机号绑定，仅用用户名/邮箱+密码登录
PHONE_BINDING_REQUIRED=False
SMS_ENABLED=False

# ==================== JWT ====================
# 自托管建议设置较长的 token 有效期（单位：小时）
JWT_ACCESS_TOKEN_HOURS=720

# ==================== 邮箱（可选）====================
# 不配置则使用控制台输出模式（验证码打印到后端日志）
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.qq.com
# EMAIL_PORT=465
# EMAIL_HOST_USER=your@qq.com
# EMAIL_HOST_PASSWORD=your_smtp_auth_code
# EMAIL_USE_SSL=true
# DEFAULT_FROM_EMAIL=your@qq.com

# ==================== OAuth 第三方登录（可选）====================
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ==================== Fava ====================
# 自托管推荐：静态实例（无需 Traefik）。先启动：docker compose --profile fava-family up -d
# 映射键 = Django 用户名（或 Git repo_name），须与解析写入目录一致：
# Docker Compose 下为 ./Beancount-Trans-Backend/Assets/<用户名>/（与 backend、worker 挂载的 Assets/<用户名> 相同）
# 从其它设备访问时，将 127.0.0.1 换为宿主机局域网 IP
FAVA_DEPLOY_MODE=static
FAVA_STATIC_USER_MAP=admin=http://127.0.0.1:5001
FAVA_IMAGE=dhr2333/beancount-trans-assets:latest
# 多用户示例（需在 compose 中为每名用户增加 Fava 服务，挂载 ./Beancount-Trans-Backend/Assets/<用户名>:/Assets）：
# FAVA_STATIC_USER_MAP=admin=http://127.0.0.1:5001,alice=http://127.0.0.1:5002

# ==================== Git / Gitea（可选，详见 Beancount-Trans-Backend/ENV_CONFIG.md）====================
# 平台托管 Gitea 的 SSH 克隆基址（无尾斜杠）；外部自建 Gitea 时请改为实际地址
# GITEA_BASE_URL=http://your-gitea-domain.com
# GITEA_ADMIN_TOKEN=
# GITEA_ORG_NAME=beancount-trans
# GITEA_WEBHOOK_SECRET=
# GIT_REPO_SIZE_LIMIT=20971520  # 20 MB
